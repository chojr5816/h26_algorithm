def partition(A, left, right):
    pivot = A[left]
    low = left + 1
    high = right

    while low <= high:
        while A[low] < pivot:
            low += 1
        while A[high] > pivot:
            high -= 1

        if low < high:
            A[low], A[high] = A[high], A[low]
    
    A[left], A[high] = A[high], A[left]
